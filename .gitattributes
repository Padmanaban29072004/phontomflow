# PHANTOM-Flow Language Detection Configuration
# Configure GitHub to detect specific languages and hide others

# Force Python detection for ML and security tools
*.py linguist-language=Python
ml_models/* linguist-language=Python
data_analysis/* linguist-language=Python
security_tools/* linguist-language=Python
blockchain_security/* linguist-language=Python
ai_models/* linguist-language=Python
quantum_security/* linguist-language=Python

# Force Go detection for backend services
*.go linguist-language=Go
cmd/* linguist-language=Go
pkg/* linguist-language=Go
internal/* linguist-language=Go

# Force Rust detection for performance-critical components
*.rs linguist-language=Rust
src/* linguist-language=Rust

# Ensure all languages are properly detected
*.ts linguist-language=TypeScript
*.js linguist-language=JavaScript
backend/src/* linguist-language=TypeScript
frontend/src/* linguist-language=TypeScript

# Exclude only vendor/generated files from statistics
backend/node_modules/* linguist-vendored
frontend/node_modules/* linguist-vendored
frontend/build/* linguist-generated
backend/dist/* linguist-generated

# Mark generated files
*.min.js linguist-generated=true
*.bundle.js linguist-generated=true
package-lock.json linguist-generated=true

# Documentation and config files (exclude from language statistics)
*.md linguist-documentation
*.yml linguist-data
*.yaml linguist-data
package.json linguist-data
tsconfig.json linguist-data
*.config.js linguist-data

# Force detection of specific file types
requirements.txt linguist-language=Python
Dockerfile linguist-language=Dockerfile
docker-compose.yml linguist-language=YAML

# Hide certain file types from statistics
*.log linguist-detectable=false
*.tmp linguist-detectable=false
*.cache linguist-detectable=false
