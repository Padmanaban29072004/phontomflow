# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/phantom-flow
REDIS_URL=redis://localhost:6379

# Development Flags (Optional)
SKIP_REDIS_CONNECTION=true
SKIP_MONGODB_CONNECTION=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External APIs
THREAT_INTELLIGENCE_API_KEY=your-threat-intelligence-api-key
GEOIP_API_KEY=your-geoip-api-key

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
SKIP_NEO4J_CONNECTION=false

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/phantom-flow.log

# ML Model Configuration
MODEL_UPDATE_INTERVAL=3600000
ANOMALY_DETECTION_THRESHOLD=0.8
BEHAVIOR_ANALYSIS_WINDOW=300000

# Deception Layer
HONEYPOT_ENABLED=true
DECEPTION_LEVEL=medium
ATTACK_RECORDING_ENABLED=true

# Performance Monitoring
METRICS_ENABLED=true
PERFORMANCE_MONITORING_INTERVAL=60000

# Enhanced Risk Scoring Configuration
RISK_SCORING_ENABLED=true
RISK_CONTEXT_SENSITIVITY=0.7
RISK_CONFIDENCE_THRESHOLD=0.5
RISK_ADAPTIVE_LEARNING=true

# Risk Thresholds
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.5
RISK_THRESHOLD_HIGH=0.7
RISK_THRESHOLD_CRITICAL=0.85

# Context Multipliers
MULTIPLIER_OFF_HOURS=1.2
MULTIPLIER_WEEKEND=1.1
MULTIPLIER_VPN_USAGE=1.3
MULTIPLIER_KNOWN_THREAT=2.0

# Graduated Response System Configuration
RESPONSE_SYSTEM_ENABLED=true
DEFAULT_RESPONSE_TIER=monitor
MAX_ESCALATIONS_PER_SESSION=5
DEFAULT_COOLDOWN_PERIOD=300000
RESPONSE_TIMEOUT=10000
ENABLE_ADAPTIVE_LEARNING=true
METRICS_RETENTION_DAYS=30

# Adaptive Learning Configuration  
ADAPTIVE_LEARNING_ENABLED=true
LEARNING_RATE=0.01
FEEDBACK_THRESHOLD=0.8
RETRAIN_INTERVAL=86400000

# Count-Min Sketch Configuration
# Default Sketch Settings
SKETCH_DEFAULT_WIDTH=4096
SKETCH_DEFAULT_DEPTH=6
SKETCH_ERROR_RATE=0.001
SKETCH_CONFIDENCE=0.99

# High Performance Sketch (for high traffic)
SKETCH_HP_WIDTH=8192
SKETCH_HP_DEPTH=8
SKETCH_HP_ERROR_RATE=0.0005
SKETCH_HP_CONFIDENCE=0.995

# Memory Efficient Sketch (for low memory environments)
SKETCH_ME_WIDTH=2048
SKETCH_ME_DEPTH=4
SKETCH_ME_ERROR_RATE=0.01
SKETCH_ME_CONFIDENCE=0.95

# Development Sketch (faster, smaller for dev)
SKETCH_DEV_WIDTH=1024
SKETCH_DEV_DEPTH=4
SKETCH_DEV_ERROR_RATE=0.01
SKETCH_DEV_CONFIDENCE=0.9

# Sketch Use-Case Specific Settings
SKETCH_IP_WIDTH=8192
SKETCH_IP_DEPTH=6
SKETCH_PATH_WIDTH=4096
SKETCH_PATH_DEPTH=5
SKETCH_UA_WIDTH=2048
SKETCH_UA_DEPTH=4
SKETCH_SESSION_WIDTH=4096
SKETCH_SESSION_DEPTH=5
SKETCH_PARAM_WIDTH=4096
SKETCH_PARAM_DEPTH=5

# Frequency Tracking Thresholds
# IP Address Tracking
ENABLE_IP_TRACKING=true
IP_BASELINE_FREQUENCY=10
IP_SUSPICIOUS_FREQUENCY=50
IP_ANOMALOUS_FREQUENCY=100
IP_CRITICAL_FREQUENCY=500
IP_TIME_WINDOW=300000

# User Agent Tracking
ENABLE_UA_TRACKING=true
UA_BASELINE_FREQUENCY=5
UA_SUSPICIOUS_FREQUENCY=20
UA_ANOMALOUS_FREQUENCY=50
UA_CRITICAL_FREQUENCY=200
UA_TIME_WINDOW=300000

# Request Path Tracking
ENABLE_PATH_TRACKING=true
PATH_BASELINE_FREQUENCY=20
PATH_SUSPICIOUS_FREQUENCY=100
PATH_ANOMALOUS_FREQUENCY=500
PATH_CRITICAL_FREQUENCY=2000
PATH_TIME_WINDOW=300000

# Session Tracking
ENABLE_SESSION_TRACKING=true
SESSION_BASELINE_FREQUENCY=50
SESSION_SUSPICIOUS_FREQUENCY=200
SESSION_ANOMALOUS_FREQUENCY=1000
SESSION_CRITICAL_FREQUENCY=5000
SESSION_TIME_WINDOW=600000

# Parameter Tracking
ENABLE_PARAM_TRACKING=true
PARAM_BASELINE_FREQUENCY=1
PARAM_SUSPICIOUS_FREQUENCY=5
PARAM_ANOMALOUS_FREQUENCY=20
PARAM_CRITICAL_FREQUENCY=100
PARAM_TIME_WINDOW=300000

# Sketch Manager Settings
SKETCH_PERSISTENCE_INTERVAL=300000
SKETCH_CLEANUP_INTERVAL=900000
SKETCH_MAX_MEMORY=200
ENABLE_SKETCH_METRICS=true

# Anomaly Detection Settings
ENABLE_FREQUENCY_SPIKE_DETECTION=true
ENABLE_RARE_ITEM_DETECTION=true
ENABLE_BURST_PATTERN_DETECTION=true
ENABLE_SUSTAINED_ACTIVITY_DETECTION=true
ANOMALY_SENSITIVITY=0.7
ANOMALY_SHORT_WINDOW=300000
ANOMALY_LONG_WINDOW=3600000
ANOMALY_MIN_SAMPLES=10
SPIKE_THRESHOLD=5.0
RARITY_THRESHOLD=0.001
BURST_VARIANCE_THRESHOLD=2.0
SUSTAINED_DURATION=600000

# HyperLogLog Configuration
# Default HLL Settings
HLL_DEFAULT_PRECISION=12
HLL_HASH_FUNCTION=murmur3
HLL_BIAS_CORRECTION=true
HLL_SPARSE_MODE=true
HLL_MAX_MEMORY_MB=50

# High Precision HLL (for accurate counting)
HLL_HIGH_PRECISION=14
HLL_HIGH_MEMORY_MB=100

# Memory Efficient HLL (for low memory environments)
HLL_MEMORY_PRECISION=8
HLL_MEMORY_LIMIT_MB=5

# Development HLL (faster, smaller for dev)
HLL_DEV_PRECISION=8
HLL_DEV_MEMORY_MB=5

# Use-Case Specific Settings
HLL_IP_PRECISION=12
HLL_IP_MEMORY_MB=30
HLL_SESSION_PRECISION=10
HLL_SESSION_MEMORY_MB=20
HLL_VISITOR_PRECISION=14
HLL_VISITOR_MEMORY_MB=50
HLL_PATH_PRECISION=10
HLL_PATH_MEMORY_MB=15

# Visitor Tracking Configuration
VISITOR_TRACK_IPS=true
VISITOR_TRACK_SESSIONS=true
VISITOR_TRACK_USER_AGENTS=true
VISITOR_TRACK_GEOLOCATION=true
VISITOR_TRACK_PATHS=true
VISITOR_TRACKING_ENABLED=true

# Time Windows for Analysis (milliseconds)
VISITOR_WINDOW_1MIN=60000
VISITOR_WINDOW_5MIN=300000
VISITOR_WINDOW_1HOUR=3600000
VISITOR_WINDOW_1DAY=86400000

# HLL Manager Settings
HLL_TRACK_IPS=true
HLL_TRACK_SESSIONS=true
HLL_TRACK_VISITORS=true
HLL_TRACK_PATHS=true
HLL_PERSISTENCE_INTERVAL=300000
HLL_CLEANUP_INTERVAL=900000
HLL_TOTAL_MEMORY_MB=200
HLL_ENABLE_METRICS=true
HLL_ENABLE_ANALYTICS=true

# ==========================================
# MARKOV CHAIN CONFIGURATION
# ==========================================

# Default Markov Chain settings
MARKOV_SMOOTHING_PARAMETER=1.0
MARKOV_PRUNING_THRESHOLD=5
MARKOV_MAX_STATES=10000
MARKOV_MEMORY_LIMIT=100
MARKOV_PERSISTENCE_INTERVAL=300000
MARKOV_STATE_EXPIRY_HOURS=168
MARKOV_MIN_CONFIDENCE=0.3

# High-accuracy Markov Chain (3rd order)
MARKOV_HA_SMOOTHING=0.5
MARKOV_HA_PRUNING_THRESHOLD=10
MARKOV_HA_MAX_STATES=50000
MARKOV_HA_MEMORY_LIMIT=500
MARKOV_HA_MIN_CONFIDENCE=0.5

# Memory-efficient Markov Chain (1st order)
MARKOV_ME_SMOOTHING=2.0
MARKOV_ME_PRUNING_THRESHOLD=3
MARKOV_ME_MAX_STATES=5000
MARKOV_ME_MEMORY_LIMIT=50
MARKOV_ME_PERSISTENCE_INTERVAL=600000
MARKOV_ME_MIN_CONFIDENCE=0.2

# Development Markov Chain
MARKOV_DEV_PRUNING_THRESHOLD=2
MARKOV_DEV_MAX_STATES=1000
MARKOV_DEV_MEMORY_LIMIT=20
MARKOV_DEV_PERSISTENCE_INTERVAL=60000
MARKOV_DEV_STATE_EXPIRY_HOURS=24
MARKOV_DEV_MIN_CONFIDENCE=0.1

# Security-focused Markov Chain
MARKOV_SEC_SMOOTHING=0.1
MARKOV_SEC_PRUNING_THRESHOLD=1
MARKOV_SEC_MAX_STATES=20000
MARKOV_SEC_MEMORY_LIMIT=200
MARKOV_SEC_PERSISTENCE_INTERVAL=180000
MARKOV_SEC_STATE_EXPIRY_HOURS=336
MARKOV_SEC_MIN_CONFIDENCE=0.05

# Real-time Markov Chain
MARKOV_RT_SMOOTHING=1.5
MARKOV_RT_PRUNING_THRESHOLD=10
MARKOV_RT_MAX_STATES=5000
MARKOV_RT_MEMORY_LIMIT=100
MARKOV_RT_PERSISTENCE_INTERVAL=30000
MARKOV_RT_STATE_EXPIRY_HOURS=72
MARKOV_RT_MIN_CONFIDENCE=0.4

# State compression
MARKOV_COMPRESSION_ENABLED=true
MARKOV_COMPRESSION_RATIO=0.7
MARKOV_PRESERVE_IMPORTANT=true
MARKOV_IMPORTANCE_THRESHOLD=5
MARKOV_COMPRESSION_ALGORITHM=hybrid

# Markov Manager configuration
MARKOV_PRIMARY_ENABLED=true
MARKOV_SECURITY_ENABLED=false
MARKOV_REALTIME_ENABLED=false
MARKOV_GLOBAL_MEMORY_LIMIT=1000
MARKOV_GLOBAL_PERSISTENCE_INTERVAL=300000
MARKOV_GLOBAL_CLEANUP_INTERVAL=3600000
MARKOV_ENABLE_METRICS=true
MARKOV_ENABLE_ANALYTICS=true
MARKOV_ENABLE_REALTIME_UPDATES=true

# Anomaly detection thresholds
MARKOV_ANOMALY_DETECTION_ENABLED=true
MARKOV_SEQUENCE_ANOMALY_THRESHOLD=0.7
MARKOV_TRANSITION_ANOMALY_THRESHOLD=0.8
MARKOV_TIMING_ANOMALY_THRESHOLD=0.6
MARKOV_ALERTING_ENABLED=false
MARKOV_ALERT_SEVERITY_THRESHOLD=high

# Integration settings
MARKOV_INTEGRATION_BEHAVIORAL=true
MARKOV_INTEGRATION_THREAT=true
MARKOV_INTEGRATION_RISK=true
MARKOV_INTEGRATION_PROFILING=false

# Performance tuning
MARKOV_ENABLE_CACHING=true
MARKOV_CACHE_SIZE=1000
MARKOV_BATCH_SIZE=100
MARKOV_MAX_CONCURRENT=10
MARKOV_ENABLE_PARALLEL=true

# Logging and monitoring
MARKOV_DEBUG_LOGS=false
MARKOV_PERFORMANCE_LOGS=true
MARKOV_ANOMALY_LOGS=true
MARKOV_LOG_LEVEL=info
MARKOV_METRICS_INTERVAL=60000

# Persistence
MARKOV_ENABLE_PERSISTENCE=true
MARKOV_PERSISTENCE_BACKEND=redis
MARKOV_BACKUP_INTERVAL=3600000
MARKOV_MAX_BACKUPS=24

# Behavioral integration weights
MARKOV_BEHAVIORAL_RISK_WEIGHT=0.3
MARKOV_BEHAVIORAL_ANOMALY_WEIGHT=0.4

# Threat detection integration
MARKOV_THREAT_ANOMALY_THRESHOLD=0.6
MARKOV_THREAT_RISK_MULTIPLIER=1.5

# Response system integration
MARKOV_RESPONSE_INTEGRATION=false
MARKOV_RESPONSE_TRIGGER_THRESHOLD=0.8
MARKOV_RESPONSE_ESCALATION_ENABLED=false

# ==========================================
# EWMA (EXPONENTIALLY WEIGHTED MOVING AVERAGE) CONFIGURATION
# ==========================================

# Default EWMA settings
EWMA_DEFAULT_ALPHA=0.2
EWMA_ADAPTIVE_ALPHA=false
EWMA_MIN_ALPHA=0.05
EWMA_MAX_ALPHA=0.5
EWMA_WINDOW_SIZE=100
EWMA_VOLATILITY_THRESHOLD=0.15
EWMA_CHANGE_THRESHOLD=0.6
EWMA_ENABLE_TREND_ANALYSIS=true
EWMA_ENABLE_OUTLIER_DETECTION=true

# EWMA Variants
EWMA_SIMPLE_ALPHA=0.2
EWMA_SIMPLE_TREND_ANALYSIS=true
EWMA_DOUBLE_ALPHA=0.15
EWMA_DOUBLE_WINDOW_SIZE=200
EWMA_ADAPTIVE_BASE_ALPHA=0.2
EWMA_ADAPTIVE_MIN_ALPHA=0.05
EWMA_ADAPTIVE_MAX_ALPHA=0.8
EWMA_ADAPTIVE_VOLATILITY_THRESHOLD=0.2
EWMA_ADAPTIVE_CHANGE_THRESHOLD=0.5

# Development EWMA
EWMA_DEV_ALPHA=0.3
EWMA_DEV_WINDOW_SIZE=50
EWMA_DEV_VOLATILITY_THRESHOLD=0.1
EWMA_DEV_CHANGE_THRESHOLD=0.8

# Production EWMA
EWMA_PROD_ALPHA=0.15
EWMA_PROD_WINDOW_SIZE=500
EWMA_PROD_VOLATILITY_THRESHOLD=0.2
EWMA_PROD_CHANGE_THRESHOLD=0.4
EWMA_PROD_ADAPTIVE_ALPHA=false

# High-frequency EWMA (1min window)
EWMA_HF_ALPHA=0.4
EWMA_HF_WINDOW_SIZE=60
EWMA_HF_VOLATILITY_THRESHOLD=0.1
EWMA_HF_CHANGE_THRESHOLD=0.9
EWMA_HF_ADAPTIVE_ALPHA=true

# Low-frequency EWMA (60min window)
EWMA_LF_ALPHA=0.05
EWMA_LF_WINDOW_SIZE=1000
EWMA_LF_VOLATILITY_THRESHOLD=0.3
EWMA_LF_CHANGE_THRESHOLD=0.2

# Baseline adaptation
EWMA_BASELINE_ADAPTATION_ENABLED=true
EWMA_ADAPTATION_RATE=0.1
EWMA_DRIFT_THRESHOLD=0.3
EWMA_VALIDATION_PERIOD=15
EWMA_ROLLBACK_THRESHOLD=0.8

# EWMA Manager settings
EWMA_ENABLE_1MIN=true
EWMA_ENABLE_5MIN=true
EWMA_ENABLE_15MIN=true
EWMA_ENABLE_60MIN=true
EWMA_CROSS_POLLINATION=false
EWMA_CONSENSUS_THRESHOLD=0.6
EWMA_MAX_MEMORY_USAGE=100
EWMA_PERSISTENCE_INTERVAL=300000
EWMA_CLEANUP_INTERVAL=3600000

# Monitoring and alerting
EWMA_ENABLE_METRICS=true
EWMA_METRICS_INTERVAL=60000
EWMA_ENABLE_ALERTING=false
EWMA_ALERT_THRESHOLD=0.8

# Performance optimization
EWMA_ENABLE_BATCHING=false
EWMA_BATCH_SIZE=10
EWMA_MAX_CONCURRENT=5
EWMA_ENABLE_CACHING=true
EWMA_CACHE_SIZE=100
EWMA_ENABLE_PARALLEL=true

# Integration with other components
EWMA_STATISTICAL_INTEGRATION=true
EWMA_STATISTICAL_RISK_WEIGHT=0.3
EWMA_STATISTICAL_ANOMALY_WEIGHT=0.4
EWMA_STATISTICAL_TREND_WEIGHT=0.2
EWMA_THREAT_INTEGRATION=true
EWMA_THREAT_ANOMALY_THRESHOLD=0.7
EWMA_THREAT_TREND_THRESHOLD=0.8
EWMA_THREAT_VOLATILITY_THRESHOLD=0.6
EWMA_ALERTING_INTEGRATION=false
EWMA_ALERT_ANOMALY_THRESHOLD=0.8
EWMA_ALERT_TREND_THRESHOLD=0.7
EWMA_ALERT_VOLATILITY_THRESHOLD=0.9

# Logging and debugging
EWMA_DEBUG_LOGS=false
EWMA_PERFORMANCE_LOGS=true
EWMA_ANOMALY_LOGS=true
EWMA_LOG_LEVEL=info

# Persistence and backup
EWMA_ENABLE_PERSISTENCE=true
EWMA_PERSISTENCE_BACKEND=redis
EWMA_BACKUP_INTERVAL=3600000
EWMA_MAX_BACKUPS=24
EWMA_COMPRESSION_ENABLED=true
EWMA_RETENTION_DAYS=7

# Anomaly detection thresholds
EWMA_ANOMALY_STATISTICAL_THRESHOLD=0.7
EWMA_ANOMALY_TREND_THRESHOLD=0.8
EWMA_ANOMALY_VOLATILITY_THRESHOLD=0.6
EWMA_ANOMALY_CHANGEPOINT_THRESHOLD=0.5
EWMA_ANOMALY_OUTLIER_THRESHOLD=2.5

# Window-specific optimization
EWMA_1MIN_ALPHA=0.4
EWMA_1MIN_RESPONSIVENESS=0.9
EWMA_1MIN_STABILITY=0.3
EWMA_1MIN_ACCURACY=0.7
EWMA_5MIN_ALPHA=0.2
EWMA_5MIN_RESPONSIVENESS=0.7
EWMA_5MIN_STABILITY=0.8
EWMA_5MIN_ACCURACY=0.85
EWMA_15MIN_ALPHA=0.1
EWMA_15MIN_RESPONSIVENESS=0.5
EWMA_15MIN_STABILITY=0.9
EWMA_15MIN_ACCURACY=0.9
EWMA_60MIN_ALPHA=0.05
