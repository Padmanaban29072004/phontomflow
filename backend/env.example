# ============================================================================
# INFLUXDB INTEGRATION CONFIGURATION
# ============================================================================

# InfluxDB Connection Settings
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=phantom_flow
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=
INFLUXDB_PROTOCOL=http
INFLUXDB_TIMEOUT=30000
INFLUXDB_POOL_SIZE=10
INFLUXDB_RETRY_ATTEMPTS=3
INFLUXDB_RETRY_DELAY=1000
INFLUXDB_PRECISION=ms
INFLUXDB_CONSISTENCY=one

# Data Retention Policies
INFLUXDB_RETENTION_RAW=7d
INFLUXDB_RETENTION_HOURLY=30d
INFLUXDB_RETENTION_DAILY=1y
INFLUXDB_RETENTION_MONTHLY=5y
INFLUXDB_RETENTION_THREAT=2y

# Cleanup and Archival
INFLUXDB_CLEANUP_SCHEDULE=0 2 * * *
INFLUXDB_ARCHIVE_BEFORE_DELETE=true
INFLUXDB_MAX_STORAGE_SIZE=10GB

# Metrics Ingestion
INFLUXDB_BATCH_SIZE=100
INFLUXDB_BATCH_TIMEOUT=5000
INFLUXDB_METRICS_ENABLED=true
INFLUXDB_PERFORMANCE_METRICS_ENABLED=true
INFLUXDB_THREAT_METRICS_ENABLED=true
INFLUXDB_BEHAVIOR_METRICS_ENABLED=true
INFLUXDB_SYSTEM_METRICS_ENABLED=true
INFLUXDB_RATE_LIMIT_METRICS_ENABLED=true

# Query and Analytics
INFLUXDB_QUERY_TIMEOUT=30000
INFLUXDB_MAX_QUERY_RESULTS=10000
INFLUXDB_CACHE_QUERIES=true
INFLUXDB_CACHE_TTL=300

# Performance Tuning
INFLUXDB_WRITE_CONCURRENCY=4
INFLUXDB_READ_CONCURRENCY=8
INFLUXDB_COMPRESSION_ENABLED=true
INFLUXDB_INDEXING_ENABLED=true

# Monitoring and Alerting
INFLUXDB_HEALTH_CHECK_INTERVAL=60000
INFLUXDB_METRICS_RETENTION_ALERT_THRESHOLD=0.8
INFLUXDB_PERFORMANCE_ALERT_THRESHOLD=5000
